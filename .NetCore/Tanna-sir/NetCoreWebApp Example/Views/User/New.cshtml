@model NetCoreWebApp_Example.Models.UserModel
@{
    ViewData["Title"] = "New User";
}

<h1>New User</h1>

<form asp-action="New" method="post">
    <div class="form-group row">
        <label class="col-sm-2 col-form-label">Email:</label>
        <div class="col-sm-10">
            <input asp-for="UserEmail" class="form-control" style="width:250px;" />
        </div>
    </div>
    <div class="form-group row">
        <label class="col-sm-2 col-form-label">Password:</label>
        <div class="col-sm-10">
            <input asp-for="passowrd" type="password" class="form-control" style="width:250px;" />
        </div>
    </div>
    <div class="form-group row mt-2">
        <div class="col-sm-10 offset-sm-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>
